---
import BaseLayout from '@layouts/BaseLayout.astro';
import { business } from '@data/business';

const PRENOM = 'Tony';
const SITE_URL = 'https://occivolt.pages.dev';
const UMAMI_SHARE_URL = 'https://cloud.umami.is/share/YeEqAWtiyvcwUvSQ';
const GOOGLE_BUSINESS_URL = business.social.googleBusiness;
const GOOGLE_REVIEW_LINK = 'https://www.google.com/search?q=Occi%27Volt+Electricit%C3%A9+Castelnaudary&ludocid=7189708307294235750#lrd=0x47a5b74e29f21497:0x63c6f99cdef2ac66,3,,,';
const WEBMASTER_EMAIL = 'marc@marc-muller.com';
const KEYSTATIC_BASE = `${SITE_URL}/keystatic/branch/main`;

const collections = [
  {
    slug: 'services',
    name: 'Services',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z" />`,
    count: 5,
    fields: ['Titre', 'Description', 'Photo', 'Badge'],
    canAdd: true,
  },
  {
    slug: 'testimonials',
    name: 'Témoignages',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />`,
    count: 2,
    fields: ['Nom', 'Avis', 'Contexte'],
    canAdd: true,
  },
  {
    slug: 'gallery',
    name: 'Galerie',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />`,
    count: 7,
    fields: ['Photo', 'Titre', 'Tag'],
    canAdd: true,
  },
  {
    slug: 'faq',
    name: 'FAQ',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />`,
    count: 8,
    fields: ['Question', 'Réponse', 'Ordre'],
    canAdd: true,
  },
];

const singletons = [
  {
    slug: 'site-info',
    name: 'Informations du site',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />`,
    fields: ['Nom', 'Slogan', 'Téléphone', 'Email', 'Adresse', 'Horaires'],
  },
];
---

<BaseLayout title={`Espace privé — ${PRENOM} | ${business.shortName}`} noindex={true}>

  <!-- Sticky tabs navigation -->
  <nav class="sticky top-0 z-40 bg-white/90 backdrop-blur-md border-b border-neutral-200 shadow-sm">
    <div class="max-w-5xl mx-auto px-4 flex items-center justify-between h-14">
      <div class="flex items-center gap-1.5">
        <button class="tab-btn text-sm font-medium px-3 py-1.5 rounded-lg transition-colors text-primary-700 bg-primary-50" data-tab="0">
          Modifier le site
        </button>
        <button class="tab-btn text-sm font-medium px-3 py-1.5 rounded-lg transition-colors text-neutral-500" data-tab="1">
          Fiche Google
        </button>
        <button class="tab-btn text-sm font-medium px-3 py-1.5 rounded-lg transition-colors text-neutral-500" data-tab="2">
          Statistiques
        </button>
      </div>
      <span class="hidden sm:block text-sm font-heading font-bold text-secondary-900">
        {PRENOM}
      </span>
    </div>
  </nav>

  <!-- Swipeable panels container -->
  <div id="panels" class="flex overflow-x-auto snap-x snap-mandatory" style="-ms-overflow-style: none; scrollbar-width: none;">

    <!-- ═══════════════════════════════════════════════ -->
    <!-- PANEL 1 — Modifier le site                     -->
    <!-- ═══════════════════════════════════════════════ -->
    <section class="tab-panel min-w-full snap-start snap-always shrink-0">
      <div class="max-w-4xl mx-auto px-4 py-10">

        <!-- Header -->
        <div class="mb-10">
          <h1 class="text-2xl md:text-3xl font-heading font-extrabold text-secondary-950 mb-3">
            Modifier le contenu du site
          </h1>
          <p class="text-neutral-500 mb-2">En 3 étapes simples :</p>
          <ol class="text-sm text-neutral-600 space-y-1 mb-6">
            <li class="flex items-start gap-2">
              <span class="bg-primary-100 text-primary-700 font-bold text-xs w-5 h-5 rounded-full flex items-center justify-center shrink-0 mt-0.5">1</span>
              Cliquez sur une rubrique ci-dessous pour l'ouvrir dans l'éditeur
            </li>
            <li class="flex items-start gap-2">
              <span class="bg-primary-100 text-primary-700 font-bold text-xs w-5 h-5 rounded-full flex items-center justify-center shrink-0 mt-0.5">2</span>
              Modifiez le texte, ajoutez des photos ou des entrées
            </li>
            <li class="flex items-start gap-2">
              <span class="bg-primary-100 text-primary-700 font-bold text-xs w-5 h-5 rounded-full flex items-center justify-center shrink-0 mt-0.5">3</span>
              Cliquez sur <strong>Save</strong> — les changements sont en ligne en quelques minutes
            </li>
          </ol>
          <a href={KEYSTATIC_BASE} target="_blank" rel="noopener noreferrer"
            class="inline-flex items-center gap-2 bg-primary-600 hover:bg-primary-700 text-white font-heading font-bold text-sm px-5 py-2.5 rounded-xl transition-colors shadow-sm">
            Modifier mes contenus
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-4.5-6l6 6m-3-9v6h6" /></svg>
          </a>
        </div>

        <!-- Collections -->
        <div class="mb-10">
          <div class="flex items-center gap-2 mb-4">
            <h2 class="text-lg font-heading font-bold text-secondary-900">Rubriques</h2>
            <span class="bg-primary-100 text-primary-700 text-[10px] font-bold px-2 py-0.5 rounded-full uppercase tracking-wider">Ajout & suppression possibles</span>
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
            {collections.map((col) => (
              <a href={`${KEYSTATIC_BASE}/collection/${col.slug}`} target="_blank" rel="noopener noreferrer"
                class="group flex items-start gap-4 bg-white rounded-xl border border-neutral-200 p-5 hover:border-primary-300 hover:shadow-md transition-all">
                <div class="w-10 h-10 bg-primary-50 rounded-lg flex items-center justify-center shrink-0 group-hover:bg-primary-600 transition-colors">
                  <svg class="w-5 h-5 text-primary-600 group-hover:text-white transition-colors" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <Fragment set:html={col.icon} />
                  </svg>
                </div>
                <div class="flex-1 min-w-0">
                  <div class="flex items-center gap-2 mb-1">
                    <h3 class="font-heading font-bold text-secondary-900 group-hover:text-primary-700 transition-colors">{col.name}</h3>
                    <span class="bg-neutral-100 text-neutral-500 text-xs font-medium px-1.5 py-0.5 rounded">{col.count}</span>
                  </div>
                  <div class="flex flex-wrap gap-1">
                    {col.fields.map((f) => (
                      <span class="text-[11px] text-neutral-400 bg-neutral-50 px-1.5 py-0.5 rounded">{f}</span>
                    ))}
                  </div>
                </div>
                <svg class="w-4 h-4 text-neutral-300 group-hover:text-primary-500 shrink-0 mt-1 transition-colors" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-4.5-6l6 6m-3-9v6h6" /></svg>
              </a>
            ))}
          </div>
        </div>

        <!-- Singletons -->
        <div class="mb-10">
          <div class="flex items-center gap-2 mb-4">
            <h2 class="text-lg font-heading font-bold text-secondary-900">Configuration</h2>
            <span class="bg-neutral-100 text-neutral-500 text-[10px] font-bold px-2 py-0.5 rounded-full uppercase tracking-wider">Modification uniquement</span>
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
            {singletons.map((s) => (
              <a href={`${KEYSTATIC_BASE}/singleton/${s.slug}`} target="_blank" rel="noopener noreferrer"
                class="group flex items-start gap-4 bg-white rounded-xl border border-neutral-200 p-5 hover:border-primary-300 hover:shadow-md transition-all">
                <div class="w-10 h-10 bg-neutral-100 rounded-lg flex items-center justify-center shrink-0 group-hover:bg-primary-600 transition-colors">
                  <svg class="w-5 h-5 text-neutral-500 group-hover:text-white transition-colors" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <Fragment set:html={s.icon} />
                  </svg>
                </div>
                <div class="flex-1 min-w-0">
                  <h3 class="font-heading font-bold text-secondary-900 group-hover:text-primary-700 transition-colors mb-1">{s.name}</h3>
                  <div class="flex flex-wrap gap-1">
                    {s.fields.map((f) => (
                      <span class="text-[11px] text-neutral-400 bg-neutral-50 px-1.5 py-0.5 rounded">{f}</span>
                    ))}
                  </div>
                </div>
                <svg class="w-4 h-4 text-neutral-300 group-hover:text-primary-500 shrink-0 mt-1 transition-colors" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-4.5-6l6 6m-3-9v6h6" /></svg>
              </a>
            ))}
          </div>
        </div>

        <!-- Conseils -->
        <div class="bg-primary-50 border border-primary-200 rounded-xl p-5">
          <div class="flex items-start gap-3">
            <svg class="w-5 h-5 text-primary-600 shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
            <div class="text-sm text-primary-800 space-y-1">
              <p><strong>Save</strong> enregistre vos modifications. Les changements apparaissent sur le site en quelques minutes.</p>
              <p>En cas d'erreur, contactez votre webmaster — une restauration est toujours possible.</p>
              <p>Besoin d'aide ? <a href={`mailto:${WEBMASTER_EMAIL}`} class="underline font-medium">{WEBMASTER_EMAIL}</a></p>
            </div>
          </div>
        </div>

      </div>
    </section>

    <!-- ═══════════════════════════════════════════════ -->
    <!-- PANEL 2 — Fiche Google                         -->
    <!-- ═══════════════════════════════════════════════ -->
    <section class="tab-panel min-w-full snap-start snap-always shrink-0">
      <div class="max-w-4xl mx-auto px-4 py-10">

        <h1 class="text-2xl md:text-3xl font-heading font-extrabold text-secondary-950 mb-8">
          Fiche Google Business
        </h1>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-8">
          <!-- Gérer la fiche -->
          <div class="bg-white rounded-xl border border-neutral-200 p-6">
            <div class="flex items-center gap-3 mb-4">
              <div class="w-10 h-10 bg-blue-50 rounded-lg flex items-center justify-center">
                <svg class="w-5 h-5 text-blue-600" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" /></svg>
              </div>
              <h2 class="font-heading font-bold text-secondary-900">Gérer la fiche</h2>
            </div>
            <p class="text-sm text-neutral-500 mb-4">Modifiez vos horaires, photos, description et répondez aux avis depuis Google Business.</p>
            <a href={GOOGLE_BUSINESS_URL} target="_blank" rel="noopener noreferrer"
              class="inline-flex items-center gap-2 bg-blue-600 hover:bg-blue-700 text-white font-medium text-sm px-4 py-2 rounded-lg transition-colors">
              Ouvrir Google Business
              <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-4.5-6l6 6m-3-9v6h6" /></svg>
            </a>
          </div>

          <!-- Demander un avis -->
          <div class="bg-white rounded-xl border border-neutral-200 p-6">
            <div class="flex items-center gap-3 mb-4">
              <div class="w-10 h-10 bg-accent-50 rounded-lg flex items-center justify-center">
                <svg class="w-5 h-5 text-accent-600" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
              </div>
              <h2 class="font-heading font-bold text-secondary-900">Demander un avis</h2>
            </div>
            <p class="text-sm text-neutral-500 mb-4">Copiez ce lien et envoyez-le à vos clients par SMS après une intervention.</p>
            <div class="flex items-center gap-2">
              <input
                id="review-link"
                type="text"
                readonly
                value={GOOGLE_REVIEW_LINK}
                class="flex-1 text-xs bg-neutral-50 border border-neutral-200 rounded-lg px-3 py-2 text-neutral-600 truncate"
              />
              <button
                id="copy-btn"
                class="shrink-0 bg-accent-500 hover:bg-accent-600 text-white font-medium text-sm px-4 py-2 rounded-lg transition-colors"
              >
                Copier
              </button>
            </div>
            <p id="copy-feedback" class="text-xs text-primary-600 mt-2 hidden">Lien copié !</p>
          </div>
        </div>

        <!-- Astuces -->
        <div class="bg-accent-50 border border-accent-200 rounded-xl p-5">
          <div class="flex items-start gap-3">
            <svg class="w-5 h-5 text-accent-600 shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path d="M11 3a1 1 0 10-2 0v1a1 1 0 102 0V3zM15.657 5.757a1 1 0 00-1.414-1.414l-.707.707a1 1 0 001.414 1.414l.707-.707zM18 10a1 1 0 01-1 1h-1a1 1 0 110-2h1a1 1 0 011 1zM5.05 6.464A1 1 0 106.464 5.05l-.707-.707a1 1 0 00-1.414 1.414l.707.707zM4 11a1 1 0 100-2H3a1 1 0 000 2h1zM10 18a1 1 0 001-1v-1a1 1 0 10-2 0v1a1 1 0 001 1z" /><path fill-rule="evenodd" d="M10 2a8 8 0 100 16 8 8 0 000-16zm0 14a6 6 0 110-12 6 6 0 010 12z" clip-rule="evenodd" /></svg>
            <div class="text-sm text-accent-800 space-y-1">
              <p><strong>Astuce :</strong> demandez un avis juste après une intervention réussie — le client est encore satisfait !</p>
              <p>Un SMS avec le lien fonctionne mieux qu'un email — le taux de réponse est 3x plus élevé.</p>
              <p>Pensez à répondre à chaque avis (même positif) pour montrer votre professionnalisme.</p>
            </div>
          </div>
        </div>

      </div>
    </section>

    <!-- ═══════════════════════════════════════════════ -->
    <!-- PANEL 3 — Statistiques                         -->
    <!-- ═══════════════════════════════════════════════ -->
    <section class="tab-panel min-w-full snap-start snap-always shrink-0">
      <div class="max-w-5xl mx-auto px-4 py-10">

        <h1 class="text-2xl md:text-3xl font-heading font-extrabold text-secondary-950 mb-8">
          Statistiques du site
        </h1>

        <!-- Desktop: iframe -->
        <div class="hidden md:block bg-white rounded-xl border border-neutral-200 overflow-hidden mb-6">
          <iframe
            src={UMAMI_SHARE_URL}
            width="100%"
            height="750"
            style="border: none;"
            title="Statistiques du site Occi'Volt"
            loading="lazy"
          ></iframe>
        </div>

        <!-- Mobile: link card -->
        <div class="md:hidden bg-white rounded-xl border border-neutral-200 p-8 text-center mb-6">
          <div class="w-14 h-14 bg-primary-50 rounded-2xl flex items-center justify-center mx-auto mb-4">
            <svg class="w-7 h-7 text-primary-600" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" /></svg>
          </div>
          <h2 class="font-heading font-bold text-secondary-900 mb-2">Vos statistiques de visite</h2>
          <p class="text-sm text-neutral-500 mb-5">Consultez le nombre de visiteurs, les pages vues et la provenance de votre audience.</p>
          <a href={UMAMI_SHARE_URL} target="_blank" rel="noopener noreferrer"
            class="inline-flex items-center gap-2 bg-primary-600 hover:bg-primary-700 text-white font-heading font-bold text-sm px-5 py-2.5 rounded-xl transition-colors">
            Voir mes statistiques
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-4.5-6l6 6m-3-9v6h6" /></svg>
          </a>
        </div>

        <!-- Button always visible -->
        <div class="text-center">
          <a href={UMAMI_SHARE_URL} target="_blank" rel="noopener noreferrer"
            class="inline-flex items-center gap-2 text-sm font-medium text-primary-600 hover:text-primary-700 transition-colors">
            Ouvrir les statistiques dans un nouvel onglet
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-4.5-6l6 6m-3-9v6h6" /></svg>
          </a>
        </div>

      </div>
    </section>

  </div>

  <!-- Footer contact -->
  <footer class="border-t border-neutral-200 py-6 text-center">
    <p class="text-sm text-neutral-500">
      Besoin d'aide ? <a href={`mailto:${WEBMASTER_EMAIL}`} class="text-primary-600 hover:text-primary-700 font-medium underline">{WEBMASTER_EMAIL}</a>
    </p>
  </footer>

  <!-- Scripts -->
  <style is:inline>
    #panels { -ms-overflow-style: none; scrollbar-width: none; }
    #panels::-webkit-scrollbar { display: none; }
  </style>

  <script is:inline>
    // Tab/swipe sync
    const panels = document.getElementById('panels');
    const tabs = document.querySelectorAll('.tab-btn');
    const sections = panels.querySelectorAll('.tab-panel');

    function activateTab(index) {
      tabs.forEach((b, i) => {
        if (i === index) {
          b.classList.remove('text-neutral-500');
          b.classList.add('text-primary-700', 'bg-primary-50');
        } else {
          b.classList.remove('text-primary-700', 'bg-primary-50');
          b.classList.add('text-neutral-500');
        }
      });
    }

    tabs.forEach((btn, i) => {
      btn.addEventListener('click', () => {
        sections[i].scrollIntoView({ behavior: 'smooth', inline: 'start', block: 'nearest' });
        activateTab(i);
      });
    });

    let scrollTimeout;
    panels.addEventListener('scroll', () => {
      clearTimeout(scrollTimeout);
      scrollTimeout = setTimeout(() => {
        const index = Math.round(panels.scrollLeft / panels.offsetWidth);
        activateTab(index);
      }, 50);
    }, { passive: true });

    // Copy review link
    const copyBtn = document.getElementById('copy-btn');
    const reviewInput = document.getElementById('review-link');
    const copyFeedback = document.getElementById('copy-feedback');

    if (copyBtn && reviewInput) {
      copyBtn.addEventListener('click', async () => {
        try {
          await navigator.clipboard.writeText(reviewInput.value);
          copyFeedback.classList.remove('hidden');
          copyBtn.textContent = 'Copié !';
          setTimeout(() => {
            copyFeedback.classList.add('hidden');
            copyBtn.textContent = 'Copier';
          }, 2000);
        } catch {
          reviewInput.select();
          document.execCommand('copy');
          copyFeedback.classList.remove('hidden');
          setTimeout(() => copyFeedback.classList.add('hidden'), 2000);
        }
      });
    }
  </script>

</BaseLayout>
