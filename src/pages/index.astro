---
import BaseLayout from '@layouts/BaseLayout.astro';
import Header from '@components/layout/Header.astro';
import Footer from '@components/layout/Footer.astro';
import StickyMobileCTA from '@components/layout/StickyMobileCTA.astro';
import Hero from '@components/sections/Hero.astro';
import SocialProof from '@components/sections/SocialProof.astro';
import Services from '@components/sections/Services.astro';
import Testimonials from '@components/sections/Testimonials.astro';
import Gallery from '@components/sections/Gallery.astro';
import About from '@components/sections/About.astro';
import FAQ from '@components/sections/FAQ.astro';
import CTA from '@components/sections/CTA.astro';
import ContactSection from '@components/sections/ContactSection.astro';
import { business } from '@data/business';
import {
  getLocalBusinessSchema,
  getWebsiteSchema,
  getFAQPageSchema,
  getBreadcrumbSchema,
  getSpeakableSchema,
} from '@data/schemas';

/* Schemas centralises — doctrine C1 wf-00-cms §7 */
const electricianSchema = getLocalBusinessSchema();
const websiteSchema = getWebsiteSchema();
const faqSchema = getFAQPageSchema();
const breadcrumbSchema = getBreadcrumbSchema([
  { name: 'Accueil', url: business.url },
]);
const speakableSchema = getSpeakableSchema(
  business.seo.defaultTitle,
  business.seo.defaultDescription,
  business.url
);
---

<BaseLayout>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(electricianSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
    {faqSchema && <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />}
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(speakableSchema)} />
  </Fragment>

  <Header />

  <main id="main-content">
    <Hero />
    <SocialProof />
    <Services />
    <Testimonials />
    <Gallery />
    <CTA />
    <About />
    <FAQ />
    <ContactSection />
  </main>

  <Footer />
  <StickyMobileCTA />
</BaseLayout>
