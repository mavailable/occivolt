---
import { business } from '@data/business';
import Button from '@components/ui/Button.astro';

const navLinks = [
  { label: 'Services', href: '#services' },
  { label: 'Réalisations', href: '#galerie' },
  { label: 'À propos', href: '#a-propos' },
  { label: 'FAQ', href: '#faq' },
  { label: 'Contact', href: '#contact' },
];
---

<header class="sticky top-0 z-50 bg-secondary-950/95 backdrop-blur-sm border-b border-secondary-800">
  <nav class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 flex items-center justify-between h-16" aria-label="Navigation principale">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-2" aria-label={`${business.shortName} — Accueil`}>
      <img src="/images/logo-occivolt.webp" alt={`Logo ${business.name}`} width="380" height="254" class="h-16 sm:h-20 w-auto" />
    </a>

    <!-- Navigation desktop -->
    <ul class="hidden md:flex items-center gap-6">
      {navLinks.map(link => (
        <li>
          <a href={link.href} class="text-neutral-300 hover:text-white text-sm font-medium transition-colors duration-150">
            {link.label}
          </a>
        </li>
      ))}
    </ul>

    <!-- CTA + Téléphone + Hamburger -->
    <div class="flex items-center gap-3">
      <!-- Téléphone mobile -->
      <a href={`tel:${business.phone}`} class="md:hidden text-white p-2" aria-label="Appeler Occi'Volt">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
        </svg>
      </a>

      <!-- CTA desktop -->
      <Button href="#contact" size="sm" class="hidden md:inline-flex">
        Devis gratuit
      </Button>

      <!-- Hamburger mobile -->
      <button
        id="menu-toggle"
        class="md:hidden text-white p-2"
        aria-label="Ouvrir le menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <svg id="icon-open" class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
        <svg id="icon-close" class="w-6 h-6 hidden" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
  </nav>

  <!-- Menu mobile -->
  <div id="mobile-menu" class="md:hidden hidden bg-secondary-950 border-t border-secondary-800">
    <ul class="px-4 py-4 space-y-1">
      {navLinks.map(link => (
        <li>
          <a href={link.href} class="mobile-nav-link block px-3 py-3 text-neutral-300 hover:text-white hover:bg-secondary-900 rounded-DEFAULT text-base font-medium transition-colors">
            {link.label}
          </a>
        </li>
      ))}
      <li class="pt-2">
        <Button href="#contact" size="md" class="w-full text-center">
          Demander mon devis gratuit
        </Button>
      </li>
    </ul>
  </div>
</header>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  const iconOpen = document.getElementById('icon-open');
  const iconClose = document.getElementById('icon-close');
  const mobileLinks = menu?.querySelectorAll('.mobile-nav-link');

  function closeMenu() {
    menu?.classList.add('hidden');
    iconOpen?.classList.remove('hidden');
    iconClose?.classList.add('hidden');
    toggle?.setAttribute('aria-expanded', 'false');
    toggle?.setAttribute('aria-label', 'Ouvrir le menu');
  }

  toggle?.addEventListener('click', () => {
    const isOpen = !menu?.classList.contains('hidden');
    if (isOpen) {
      closeMenu();
    } else {
      menu?.classList.remove('hidden');
      iconOpen?.classList.add('hidden');
      iconClose?.classList.remove('hidden');
      toggle?.setAttribute('aria-expanded', 'true');
      toggle?.setAttribute('aria-label', 'Fermer le menu');
    }
  });

  // Fermer au clic sur un lien
  mobileLinks?.forEach(link => link.addEventListener('click', closeMenu));

  // Fermer avec Echap
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeMenu();
  });
</script>
