---
import { business } from '@data/business';
---

<!-- Bouton CTA fixe en bas d'écran sur mobile uniquement -->
<div class="fixed bottom-0 left-0 right-0 z-40 md:hidden bg-white/95 backdrop-blur-sm border-t border-neutral-200 p-3 pb-[calc(0.75rem+env(safe-area-inset-bottom))]">
  <div class="flex gap-2">
    <a
      href={`tel:${business.phone}`}
      class="flex-shrink-0 inline-flex items-center justify-center bg-primary-600 text-white rounded-DEFAULT min-h-[44px] px-4 hover:bg-primary-700 transition-colors"
      aria-label="Appeler Occi'Volt"
    >
      <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
      </svg>
    </a>
    <a
      href="#contact"
      class="flex-1 inline-flex items-center justify-center bg-accent-500 text-secondary-950 font-semibold rounded-DEFAULT min-h-[44px] px-4 hover:bg-accent-600 transition-colors text-center"
    >
      Demander mon devis gratuit
    </a>
  </div>
</div>
