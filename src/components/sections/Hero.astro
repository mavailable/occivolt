---
import Button from '@components/ui/Button.astro';
import { business } from '@data/business';
---

<section id="hero" class="relative bg-secondary-950 text-white overflow-hidden min-h-[90vh] flex items-center">
  <!-- Background image with overlay -->
  <div class="absolute inset-0" aria-hidden="true">
    <img src="/images/galerie/avant-apres-tableau.jpg" alt="" class="w-full h-full object-cover opacity-15" loading="eager" />
    <div class="absolute inset-0 bg-gradient-to-r from-secondary-950 via-secondary-950/95 to-secondary-950/70"></div>
  </div>

  <!-- Grid pattern subtle -->
  <div class="absolute inset-0 opacity-[0.03]" aria-hidden="true"
    style="background-image: url(&quot;data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='1'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E&quot;)">
  </div>

  <!-- Accent line left -->
  <div class="absolute left-0 top-0 w-1 h-full bg-gradient-to-b from-transparent via-accent-500 to-transparent opacity-40" aria-hidden="true"></div>

  <div class="relative max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-20 md:py-28 w-full">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
      <!-- Texte -->
      <div>
        <div class="inline-flex items-center gap-2 bg-accent-500/10 border border-accent-500/30 rounded-full px-4 py-1.5 mb-8">
          <span class="w-2 h-2 bg-accent-400 rounded-full animate-pulse" aria-hidden="true"></span>
          <span class="text-sm text-accent-300 font-semibold tracking-wide uppercase">Électricien pour particuliers</span>
        </div>

        <h1 class="text-4xl sm:text-5xl md:text-6xl font-heading font-extrabold text-white leading-[1.1] mb-6">
          Votre électricien à
          <span class="relative inline-block">
            <span class="relative z-10 text-accent-400">Castelnaudary</span>
            <span class="absolute bottom-1 left-0 w-full h-3 bg-accent-500/20 -skew-x-3 rounded" aria-hidden="true"></span>
          </span>
          <br class="hidden sm:block" />et dans tout le Lauragais
        </h1>

        <p class="text-lg text-neutral-300 leading-relaxed mb-8 max-w-xl">
          Installation, rénovation, dépannage et mise en conformité. Un artisan réactif, à l'écoute, et des devis gratuits sans engagement.
        </p>

        <div class="flex flex-col sm:flex-row gap-4 mb-8">
          <Button href="#contact" size="lg">
            Demander mon devis gratuit
          </Button>
          <a href={`tel:${business.phone}`} class="inline-flex items-center justify-center gap-2 px-6 py-3 text-white border-2 border-neutral-600 rounded-DEFAULT hover:border-neutral-400 hover:bg-white/5 transition-all min-h-[44px] font-semibold">
            <svg class="w-5 h-5 text-primary-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            {business.phoneDisplay}
          </a>
        </div>

        <div class="flex flex-wrap gap-6 text-sm">
          {['Devis gratuit', 'Intervention rapide', 'Norme NF C 15-100'].map(item => (
            <span class="flex items-center gap-2 text-neutral-400">
              <span class="flex items-center justify-center w-6 h-6 bg-primary-600/30 rounded-full">
                <svg class="w-3.5 h-3.5 text-primary-400" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                </svg>
              </span>
              {item}
            </span>
          ))}
        </div>
      </div>

      <!-- Photo highlight -->
      <div class="hidden lg:block relative">
        <div class="relative rounded-2xl overflow-hidden shadow-2xl shadow-black/40 border border-white/10">
          <img src="/images/galerie/eclairage-jardin.jpg" alt="Éclairage extérieur réalisé par Occi'Volt dans un jardin du Lauragais" class="w-full aspect-[4/5] object-cover" loading="eager" />
          <div class="absolute inset-0 bg-gradient-to-t from-secondary-950/60 via-transparent to-transparent"></div>
          <div class="absolute bottom-4 left-4 right-4 bg-white/10 backdrop-blur-md rounded-lg p-3 border border-white/20">
            <div class="flex items-center gap-3">
              <div class="flex gap-0.5">
                {Array.from({ length: 5 }).map(() => (
                  <svg class="w-4 h-4 text-accent-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
                ))}
              </div>
              <span class="text-white text-sm font-semibold">5.0/5 sur Google</span>
            </div>
          </div>
        </div>
        <div class="absolute -bottom-4 -right-4 w-32 h-32 bg-accent-500/20 rounded-2xl -z-10" aria-hidden="true"></div>
        <div class="absolute -top-4 -left-4 w-20 h-20 bg-primary-500/20 rounded-xl -z-10" aria-hidden="true"></div>
      </div>
    </div>
  </div>
</section>
