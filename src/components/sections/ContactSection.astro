---
import ContactForm from '@components/forms/ContactForm.astro';
import { business } from '@data/business';
---

<section id="contact" class="relative py-20 md:py-24 bg-white overflow-hidden">
  <!-- Decorative -->
  <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-primary-300 to-transparent" aria-hidden="true"></div>
  <div class="absolute bottom-0 right-0 w-64 h-64 bg-primary-50/80 rounded-full blur-3xl -z-0" aria-hidden="true"></div>

  <div class="relative max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-14">
      <span class="inline-block text-xs font-bold text-primary-600 uppercase tracking-widest mb-3">Contact</span>
      <h2 class="text-3xl md:text-4xl font-heading font-bold text-secondary-900 mb-4" data-cms-field="site-info.contactTitle" data-cms-type="text">
        Parlons de <span class="text-primary-600">votre projet</span>
      </h2>
      <p class="text-neutral-500 max-w-2xl mx-auto" data-cms-field="site-info.contactSubtitle" data-cms-type="text">Décrivez-nous votre besoin et recevez un devis gratuit sous 24h. Nous vous répondons avec plaisir.</p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-5 gap-10 lg:gap-16">
      <!-- Formulaire -->
      <div class="lg:col-span-3">
        <div class="bg-neutral-50 rounded-2xl p-6 md:p-8 border border-neutral-100">
          <ContactForm />
        </div>
      </div>

      <!-- Coordonnées -->
      <aside class="lg:col-span-2">
        <div class="bg-secondary-950 rounded-2xl p-6 md:p-8 space-y-6 shadow-xl">
          <h3 class="font-heading font-bold text-white text-lg">Coordonnées</h3>

          <!-- Téléphone -->
          <div class="flex items-start gap-4">
            <div class="w-11 h-11 bg-primary-600/20 rounded-xl flex items-center justify-center shrink-0">
              <svg class="w-5 h-5 text-primary-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
            </div>
            <div>
              <p class="text-sm text-neutral-400">Téléphone</p>
              <a href={`tel:${business.phone}`} class="font-semibold text-white hover:text-accent-400 transition-colors">
                {business.phoneDisplay}
              </a>
            </div>
          </div>

          <!-- Email -->
          <div class="flex items-start gap-4">
            <div class="w-11 h-11 bg-primary-600/20 rounded-xl flex items-center justify-center shrink-0">
              <svg class="w-5 h-5 text-primary-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
            </div>
            <div>
              <p class="text-sm text-neutral-400">Email</p>
              <a href={`mailto:${business.email}`} class="font-semibold text-white hover:text-accent-400 transition-colors break-all">
                {business.email}
              </a>
            </div>
          </div>

          <!-- Zone -->
          <div class="flex items-start gap-4">
            <div class="w-11 h-11 bg-primary-600/20 rounded-xl flex items-center justify-center shrink-0">
              <svg class="w-5 h-5 text-primary-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
            </div>
            <div>
              <p class="text-sm text-neutral-400">Zone d'intervention</p>
              <p class="font-semibold text-white">Castelnaudary & Lauragais</p>
              <p class="text-xs text-neutral-400 mt-0.5">Aude (11) — rayon {business.zone.chantiers}</p>
            </div>
          </div>

          <!-- Horaires -->
          <div class="flex items-start gap-4">
            <div class="w-11 h-11 bg-primary-600/20 rounded-xl flex items-center justify-center shrink-0">
              <svg class="w-5 h-5 text-primary-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <div>
              <p class="text-sm text-neutral-400">Horaires</p>
              <p class="font-semibold text-white">{business.hours[0].day} — {business.hours[4].day}</p>
              <p class="text-sm text-neutral-400">{business.hours[0].open} – {business.hours[0].close}</p>
            </div>
          </div>

          <!-- Divider -->
          <div class="border-t border-secondary-800 pt-5">
            <div class="flex items-center gap-3">
              <div class="flex gap-0.5" aria-hidden="true">
                {Array.from({ length: 5 }).map(() => (
                  <svg class="w-4 h-4 text-accent-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
                ))}
              </div>
              <span class="text-sm text-white font-semibold" aria-label={`Note de ${business.rating.value} sur 5 étoiles sur Google`}>{business.rating.value}/5 sur Google</span>
            </div>
            <p class="text-xs text-neutral-400 mt-2">Clients 100% satisfaits</p>
          </div>
        </div>
      </aside>
    </div>
  </div>
</section>
