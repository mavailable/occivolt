---
import { getServices } from '@data/content';

// Doctrine CMS : source unique de verite dans src/content/services/*.json
// Le schema.org lit aussi cette source via getServicesSchema() dans schemas.ts.
const services = getServices();
---

<section id="services" class="relative py-20 md:py-28 bg-neutral-50 overflow-hidden">
  <!-- Background texture -->
  <div class="absolute inset-0 opacity-[0.015]" aria-hidden="true"
    style="background-image: url('data:image/svg+xml,<svg width=&quot;60&quot; height=&quot;60&quot; viewBox=&quot;0 0 60 60&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;><g fill=&quot;none&quot; fill-rule=&quot;evenodd&quot;><g fill=&quot;%23000&quot; fill-opacity=&quot;1&quot;><path d=&quot;M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z&quot;/></g></g></svg>');"></div>

  <div class="relative max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="text-center mb-14">
      <span class="inline-block text-xs font-bold text-primary-600 uppercase tracking-widest mb-3">Nos services</span>
      <h2 class="text-3xl md:text-4xl font-heading font-extrabold text-secondary-950 leading-tight mb-4">
        Des solutions électriques <span class="text-primary-600">adaptées à chaque projet</span>
      </h2>
      <p class="text-neutral-500 max-w-xl mx-auto">
        Que ce soit pour une installation neuve, une rénovation ou un dépannage urgent, nous avons la solution.
      </p>
    </div>

    <!-- Services — compact cards with photo strip -->
    <div class="space-y-4">
      {services.map((s, i) => (
        <article class="group relative bg-white rounded-xl border border-neutral-200/80 overflow-hidden shadow-sm hover:shadow-lg transition-all duration-300">
          <div class={`flex flex-col sm:flex-row items-stretch ${i % 2 !== 0 ? 'sm:flex-row-reverse' : ''}`}>
            <!-- Photo — narrow strip -->
            <div class="relative sm:w-48 md:w-56 shrink-0 overflow-hidden">
              <img
                src={s.photo}
                alt={s.photoAlt}
                class="w-full h-40 sm:h-full object-cover transition-transform duration-500 group-hover:scale-105"
                loading="lazy"
              />
              <div class="absolute inset-0 bg-secondary-950/20"></div>
              <span class="absolute top-3 left-3 text-white/15 text-5xl font-heading font-black leading-none" aria-hidden="true">{s.number}</span>
            </div>

            <!-- Content — compact -->
            <div class="flex-1 p-5 md:p-7 flex items-center">
              <div class="flex items-start gap-4 w-full">
                <div class="w-11 h-11 bg-primary-50 rounded-lg flex items-center justify-center shrink-0 group-hover:bg-primary-600 transition-colors duration-300">
                  <svg class="w-5 h-5 text-primary-600 group-hover:text-white transition-colors duration-300" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
                    <Fragment set:html={s.icon} />
                  </svg>
                </div>
                <div class="flex-1 min-w-0">
                  <div class="flex items-center gap-2.5 mb-1.5">
                    <h3 class="text-lg md:text-xl font-heading font-bold text-secondary-950">{s.title}</h3>
                    {s.badge && (
                      <span class="bg-accent-100 text-accent-800 text-[10px] font-bold px-2 py-0.5 rounded-full uppercase tracking-wider">
                        {s.badge}
                      </span>
                    )}
                  </div>
                  <p class="text-neutral-500 text-sm leading-relaxed">{s.description}</p>
                </div>
              </div>
            </div>
          </div>
        </article>
      ))}
    </div>

    <!-- CTA intégré dans la dernière carte -->
    <a href="#contact" class="group/cta flex items-center justify-center gap-3 mt-4 py-5 bg-primary-600 hover:bg-primary-700 text-white font-heading font-bold text-lg rounded-xl transition-all duration-300 hover:shadow-lg">
      Demander un devis gratuit
      <svg class="w-5 h-5 group-hover/cta:translate-x-1 transition-transform" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
    </a>
  </div>
</section>
