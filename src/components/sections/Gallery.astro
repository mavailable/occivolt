---
const images = [
  {
    src: '/images/galerie/avant-apres-tableau.webp',
    alt: "Avant/après : remplacement d'un tableau électrique vétuste par un tableau neuf aux normes — Occi'Volt Électricité",
    label: 'Avant / Après tableau',
    tag: 'Rénovation',
    span: 'lg:col-span-2 lg:row-span-2',
    aspect: 'aspect-square',
  },
  {
    src: '/images/galerie/eclairage-jardin.webp',
    alt: "Éclairage extérieur avec niches lumineuses intégrées dans un mur de jardin — Occi'Volt",
    label: 'Éclairage jardin',
    tag: 'Extérieur',
    span: '',
    aspect: 'aspect-[4/3]',
  },
  {
    src: '/images/galerie/coffret-exterieur.webp',
    alt: "Installation d'un coffret électrique extérieur étanche — Occi'Volt Électricité",
    label: 'Coffret extérieur',
    tag: 'Installation',
    span: '',
    aspect: 'aspect-[4/3]',
  },
  {
    src: '/images/galerie/tableau-3-rangees.webp',
    alt: "Tableau électrique neuf trois rangées installé par Occi'Volt",
    label: 'Tableau 3 rangées',
    tag: 'Neuf',
    span: '',
    aspect: 'aspect-[4/3]',
  },
  {
    src: '/images/galerie/spots-plafond.webp',
    alt: "Spots LED encastrés dans un faux plafond — Occi'Volt Électricité",
    label: 'Spots LED encastrés',
    tag: 'Éclairage',
    span: '',
    aspect: 'aspect-[4/3]',
  },
  {
    src: '/images/galerie/tableau-linky.webp',
    alt: "Tableau électrique après installation complète — Occi'Volt",
    label: 'Tableau électrique',
    tag: 'Mise aux normes',
    span: '',
    aspect: 'aspect-[4/3]',
  },
  {
    src: '/images/galerie/coffret-secondaire.webp',
    alt: "Coffret secondaire avec disjoncteur différentiel — Occi'Volt Électricité",
    label: 'Coffret secondaire',
    tag: 'Installation',
    span: '',
    aspect: 'aspect-[4/3]',
  },
];
---

<section id="galerie" class="relative py-20 md:py-24 bg-secondary-950 overflow-hidden">
  <!-- Decorative elements -->
  <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-accent-500/40 to-transparent" aria-hidden="true"></div>
  <div class="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-primary-500/30 to-transparent" aria-hidden="true"></div>

  <div class="relative max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-14">
      <span class="inline-block text-xs font-bold text-accent-400 uppercase tracking-widest mb-3">Réalisations</span>
      <h2 class="text-3xl md:text-4xl font-heading font-bold text-white mb-4" data-cms-field="site-info.galleryTitle" data-cms-type="text">
        Nos chantiers <span class="text-accent-400">en images</span>
      </h2>
      <p class="text-neutral-400 max-w-2xl mx-auto" data-cms-field="site-info.gallerySubtitle" data-cms-type="text">Installations, rénovations et dépannages réalisés dans le Lauragais. Chaque photo témoigne de notre savoir-faire.</p>
    </div>

    <!-- Masonry-style grid -->
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-3 md:gap-4">
      {images.map((img, i) => (
        <figure class={`group relative overflow-hidden rounded-xl ${img.span} ${i === 0 ? 'col-span-2 row-span-2' : ''}`}>
          <div class={`relative ${i === 0 ? 'aspect-square' : 'aspect-[4/3]'} overflow-hidden`}>
            <img
              src={img.src}
              alt={img.alt}
              class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
              loading={i < 2 ? 'eager' : 'lazy'}
            />
            <!-- Dark overlay on hover -->
            <div class="absolute inset-0 bg-gradient-to-t from-secondary-950/90 via-secondary-950/20 to-transparent opacity-60 group-hover:opacity-90 transition-opacity duration-300"></div>

            <!-- Tag -->
            <span class="absolute top-3 left-3 bg-accent-500/90 text-secondary-950 text-[10px] font-bold px-2.5 py-1 rounded-full uppercase tracking-wider backdrop-blur-sm">
              {img.tag}
            </span>

            <!-- Label -->
            <figcaption class="absolute bottom-0 left-0 right-0 p-4">
              <p class="text-white font-heading font-bold text-sm md:text-base translate-y-1 group-hover:translate-y-0 transition-transform duration-300">
                {img.label}
              </p>
              <div class="h-0.5 w-0 group-hover:w-12 bg-accent-400 mt-1.5 transition-all duration-500"></div>
            </figcaption>
          </div>
        </figure>
      ))}
    </div>

    <!-- Footer link -->
    <div class="text-center mt-10">
      <p class="text-neutral-400 text-sm mb-4">Photos de chantiers réels réalisés par Occi'Volt dans le Lauragais</p>
      <a href="#contact" class="inline-flex items-center gap-2 text-sm font-medium text-accent-400 hover:text-accent-300 transition-colors">
        Un projet similaire ? Demandez votre devis
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
      </a>
    </div>
  </div>
</section>
