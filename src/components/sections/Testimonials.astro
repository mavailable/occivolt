---
import { getTestimonials } from '@data/content';

// Doctrine CMS : source unique de verite dans src/content/testimonials/*.json
const testimonials = getTestimonials();
---

<section id="temoignages" class="relative py-20 md:py-24 bg-neutral-50 overflow-hidden">
  <!-- Decorative quote -->
  <div class="absolute top-8 left-8 text-neutral-200 opacity-50" aria-hidden="true">
    <svg class="w-24 h-24" fill="currentColor" viewBox="0 0 24 24"><path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10H14.017zM0 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151C7.546 6.068 5.983 8.789 5.983 11h4v10H0z"/></svg>
  </div>

  <div class="relative max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-14">
      <span class="inline-block text-xs font-bold text-primary-600 uppercase tracking-widest mb-3">Témoignages</span>
      <h2 class="text-3xl md:text-4xl font-heading font-bold text-secondary-900">
        Ce que disent <span class="text-primary-600">nos clients</span>
      </h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-4xl mx-auto">
      {testimonials.map((t) => (
        <article class="relative bg-white rounded-2xl p-8 shadow-sm border border-neutral-100 hover:shadow-md transition-shadow">
          <!-- Stars -->
          <div class="flex gap-0.5 mb-5">
            {Array.from({ length: 5 }).map(() => (
              <svg class="w-5 h-5 text-accent-400" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
            ))}
          </div>

          <!-- Quote -->
          <blockquote class="text-neutral-600 leading-relaxed mb-6">
            <p>"{t.quote}"</p>
          </blockquote>

          <!-- Author -->
          <footer class="flex items-center gap-3 pt-5 border-t border-neutral-100">
            <div class={`w-11 h-11 ${t.color} rounded-full flex items-center justify-center shadow-sm`}>
              <span class="text-white font-bold text-sm">{t.initials}</span>
            </div>
            <div>
              <cite class="not-italic font-bold text-secondary-900">{t.name}</cite>
              <p class="text-xs text-neutral-600">{t.context}</p>
            </div>
            <div class="ml-auto">
              <svg class="w-5 h-5 text-neutral-300" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 01-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" fill="#4285F4"/>
                <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
                <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
                <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
              </svg>
            </div>
          </footer>
        </article>
      ))}
    </div>

    <div class="text-center mt-8">
      <a href="https://maps.app.goo.gl/occivolt" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 text-sm font-medium text-primary-600 hover:text-primary-700 transition-colors">
        Voir tous nos avis Google
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
      </a>
    </div>
  </div>
</section>
