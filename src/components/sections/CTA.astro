---
import Button from '@components/ui/Button.astro';
import { business } from '@data/business';

interface Props {
  title?: string;
  subtitle?: string;
}

const {
  title = 'Un projet électrique en tête ?',
  subtitle = 'Contactez-nous pour un devis gratuit et sans engagement. Réponse sous 24h.',
} = Astro.props;
---

<section class="relative py-20 md:py-24 overflow-hidden">
  <!-- Background with diagonal split -->
  <div class="absolute inset-0 bg-secondary-950" aria-hidden="true"></div>
  <div class="absolute inset-0 bg-gradient-to-br from-primary-900/80 via-primary-800/60 to-secondary-950" aria-hidden="true"></div>

  <!-- Decorative elements -->
  <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-accent-500/40 to-transparent" aria-hidden="true"></div>
  <div class="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-primary-400/30 to-transparent" aria-hidden="true"></div>

  <!-- Lightning bolt decorative -->
  <div class="absolute right-8 md:right-20 top-1/2 -translate-y-1/2 opacity-[0.04]" aria-hidden="true">
    <svg class="w-48 h-48 md:w-72 md:h-72 text-accent-400" fill="currentColor" viewBox="0 0 24 24">
      <path d="M13 10V3L4 14h7v7l9-11h-7z" />
    </svg>
  </div>

  <!-- Dot pattern -->
  <div class="absolute left-0 top-0 w-full h-full opacity-[0.03]" aria-hidden="true"
    style="background-image: radial-gradient(circle, #ffffff 1px, transparent 1px); background-size: 24px 24px;">
  </div>

  <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <!-- Badge -->
    <div class="inline-flex items-center gap-2 bg-accent-500/15 border border-accent-500/30 rounded-full px-4 py-1.5 mb-8">
      <svg class="w-4 h-4 text-accent-400" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
        <path d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-8.707l-3-3a1 1 0 00-1.414 1.414L10.586 9H7a1 1 0 100 2h3.586l-1.293 1.293a1 1 0 101.414 1.414l3-3a1 1 0 000-1.414z" />
      </svg>
      <span class="text-sm text-accent-300 font-semibold">Devis gratuit sous 24h</span>
    </div>

    <h2 class="text-3xl md:text-5xl font-heading font-extrabold text-white mb-6 leading-tight" data-cms-field="site-info.ctaTitle" data-cms-type="text">
      {title}
    </h2>
    <p class="text-lg md:text-xl text-neutral-300 mb-10 leading-relaxed max-w-2xl mx-auto" data-cms-field="site-info.ctaSubtitle" data-cms-type="text">
      {subtitle}
    </p>

    <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-8">
      <Button href="#contact" size="lg">
        Demander mon devis gratuit
      </Button>
      <a
        href={`tel:${business.phone}`}
        class="inline-flex items-center gap-3 px-6 py-3.5 bg-white/10 backdrop-blur-sm border border-white/20 rounded-DEFAULT text-white hover:bg-white/20 transition-all font-semibold min-h-[44px]"
      >
        <svg class="w-5 h-5 text-accent-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
        </svg>
        {business.phoneDisplay}
      </a>
    </div>

    <!-- Trust signals -->
    <div class="flex flex-wrap items-center justify-center gap-6 text-sm text-neutral-400">
      {['Sans engagement', 'Réponse rapide', 'Artisan local'].map(item => (
        <span class="flex items-center gap-2">
          <svg class="w-4 h-4 text-primary-400" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
            <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
          </svg>
          {item}
        </span>
      ))}
    </div>
  </div>
</section>
