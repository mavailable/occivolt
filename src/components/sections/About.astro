---
import Button from '@components/ui/Button.astro';
import { business } from '@data/business';
import { getAbout } from '@data/content';

const about = getAbout();

const iconPaths: Record<string, string> = {
  lightning: '<path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z" />',
  location: '<path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />',
  check: '<path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />',
  currency: '<path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />',
};
---

<section id="a-propos" class="relative py-20 md:py-24 bg-white overflow-hidden" data-cms-field="about" data-cms-type="singleton">
  <!-- Decorative dots pattern -->
  <div class="absolute top-0 right-0 w-64 h-64 opacity-[0.03]" aria-hidden="true"
    style="background-image: radial-gradient(circle, #2E7B37 1px, transparent 1px); background-size: 20px 20px;">
  </div>

  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">

      <!-- Photo side -->
      <div class="relative">
        <!-- Main photo -->
        <div class="relative rounded-2xl overflow-hidden shadow-2xl">
          <img
            src={about.image}
            alt={about.imageAlt}
            class="w-full aspect-[4/3] object-cover"
            loading="lazy"
            data-cms-field="about.image"
            data-cms-type="image"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-secondary-950/40 via-transparent to-transparent"></div>
        </div>

        <!-- Floating card -->
        <div class="absolute -bottom-6 -right-4 md:right-4 bg-white rounded-xl shadow-lg border border-neutral-100 p-4 max-w-[200px]">
          <div class="flex items-center gap-3">
            <div class="w-12 h-12 bg-primary-100 rounded-lg flex items-center justify-center">
              <svg class="w-6 h-6 text-primary-600" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
              </svg>
            </div>
            <div>
              <p class="text-2xl font-heading font-extrabold text-secondary-900" data-cms-field="about.floatingCard.value" data-cms-type="text">{about.floatingCard.value}</p>
              <p class="text-xs text-neutral-600" data-cms-field="about.floatingCard.label" data-cms-type="text">{about.floatingCard.label}</p>
            </div>
          </div>
        </div>

        <!-- Decorative shapes -->
        <div class="absolute -top-4 -left-4 w-24 h-24 bg-primary-500/10 rounded-2xl -z-10" aria-hidden="true"></div>
        <div class="absolute -bottom-4 -left-8 w-16 h-16 bg-accent-400/15 rounded-xl -z-10" aria-hidden="true"></div>
      </div>

      <!-- Text side -->
      <div>
        <span class="inline-block text-xs font-bold text-primary-600 uppercase tracking-widest mb-3" data-cms-field="about.sectionLabel" data-cms-type="text">{about.sectionLabel}</span>
        <h2 class="text-3xl md:text-4xl font-heading font-bold text-secondary-900 mb-6" data-cms-field="about.title" data-cms-type="text">
          {about.title} <span class="text-primary-600">{about.titleHighlight}</span>
        </h2>

        <div class="space-y-4 text-neutral-600 leading-relaxed" data-cms-field="about.paragraphs" data-cms-type="rich-text">
          {about.paragraphs.map((p) => (
            <p set:html={p} />
          ))}
        </div>

        <!-- Key points -->
        <div class="grid grid-cols-2 gap-4 mt-8 mb-8" data-cms-field="about.keyPoints" data-cms-type="list">
          {about.keyPoints.map(item => (
            <div class="flex items-start gap-3">
              <div class="w-10 h-10 bg-primary-50 rounded-lg flex items-center justify-center shrink-0">
                <svg class="w-5 h-5 text-primary-600" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
                  <Fragment set:html={iconPaths[item.icon] || ''} />
                </svg>
              </div>
              <div>
                <p class="font-heading font-bold text-secondary-900 text-sm">{item.label}</p>
                <p class="text-xs text-neutral-600">{item.desc}</p>
              </div>
            </div>
          ))}
        </div>

        <Button href={about.ctaLink} size="lg">
          {about.ctaLabel}
        </Button>
      </div>
    </div>
  </div>
</section>
