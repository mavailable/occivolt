---
import { business } from '@data/business';
---

<section id="preuve-sociale" class="relative bg-secondary-950 py-6 border-y border-secondary-800 overflow-hidden">
  <!-- Subtle gradient -->
  <div class="absolute inset-0 bg-gradient-to-r from-primary-950/50 via-transparent to-primary-950/50" aria-hidden="true"></div>

  <div class="relative max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-6 md:gap-0 md:divide-x md:divide-secondary-800">

      <article class="text-center md:px-6">
        <div class="text-3xl font-heading font-extrabold text-white">
          {business.rating.value}<span class="text-accent-400">/5</span>
        </div>
        <div class="flex justify-center gap-0.5 mt-1 mb-1" aria-label="Note de 5 sur 5 étoiles">
          {Array.from({ length: 5 }).map(() => (
            <svg class="w-4 h-4 text-accent-400" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
          ))}
        </div>
        <p class="text-xs text-neutral-500 uppercase tracking-wider">Note Google</p>
      </article>

      <article class="text-center md:px-6">
        <div class="text-3xl font-heading font-extrabold text-white">3<span class="text-primary-400">+</span></div>
        <p class="text-sm text-neutral-400 mt-1">années</p>
        <p class="text-xs text-neutral-500 uppercase tracking-wider">d'expérience</p>
      </article>

      <article class="text-center md:px-6">
        <div class="text-3xl font-heading font-extrabold text-white">50<span class="text-primary-400"> km</span></div>
        <p class="text-sm text-neutral-400 mt-1">de rayon</p>
        <p class="text-xs text-neutral-500 uppercase tracking-wider">Zone chantiers</p>
      </article>

      <article class="text-center md:px-6">
        <div class="text-3xl font-heading font-extrabold text-white">100<span class="text-accent-400">%</span></div>
        <p class="text-sm text-neutral-400 mt-1">particuliers</p>
        <p class="text-xs text-neutral-500 uppercase tracking-wider">à votre service</p>
      </article>
    </div>
  </div>
</section>
