---
interface Props {
  title: string;
  subtitle?: string;
  centered?: boolean;
  class?: string;
}

const { title, subtitle, centered = true, class: className = '' } = Astro.props;
const alignClass = centered ? 'text-center' : '';
---

<div class={`mb-12 ${alignClass} ${className}`.trim()}>
  <h2 class="text-2xl md:text-3xl font-heading font-bold text-primary-900 mb-3">
    {title}
  </h2>
  {subtitle && (
    <p class="text-neutral-600 text-lg max-w-2xl mx-auto">
      {subtitle}
    </p>
  )}
</div>
