---
interface Props {
  variant?: 'primary' | 'secondary' | 'outline' | 'ghost';
  size?: 'sm' | 'md' | 'lg';
  href?: string;
  type?: 'button' | 'submit';
  class?: string;
  ariaLabel?: string;
}

const {
  variant = 'primary',
  size = 'md',
  href,
  type = 'button',
  class: className = '',
  ariaLabel,
} = Astro.props;

const baseClasses = 'inline-flex items-center justify-center font-body font-semibold transition-all duration-150 ease-in-out focus-visible:outline-2 focus-visible:outline-accent-500 focus-visible:outline-offset-2 cursor-pointer';

const variantClasses = {
  primary: 'bg-accent-500 text-secondary-950 hover:bg-accent-600 hover:shadow-md active:bg-accent-700',
  secondary: 'bg-primary-600 text-white hover:bg-primary-700 active:bg-primary-800',
  outline: 'border-2 border-primary-600 text-primary-700 hover:bg-primary-50 active:bg-primary-100',
  ghost: 'text-primary-700 hover:bg-primary-50 active:bg-primary-100',
};

const sizeClasses = {
  sm: 'px-4 py-2 text-sm rounded-DEFAULT min-h-[36px]',
  md: 'px-6 py-3 text-base rounded-DEFAULT min-h-[44px]',
  lg: 'px-8 py-4 text-lg rounded-lg min-h-[52px]',
};

const classes = `${baseClasses} ${variantClasses[variant]} ${sizeClasses[size]} ${className}`.trim();
const Tag = href ? 'a' : 'button';
---

{href ? (
  <a href={href} class={classes} aria-label={ariaLabel}>
    <slot />
  </a>
) : (
  <button type={type} class={classes} aria-label={ariaLabel}>
    <slot />
  </button>
)}
