---
import Button from '@components/ui/Button.astro';
import { business } from '@data/business';

interface Props {
  class?: string;
}

const { class: className = '' } = Astro.props;

/**
 * Web3Forms — Remplacer VOTRE_CLE par la clé d'accès Web3Forms.
 * Créer une clé gratuite sur https://web3forms.com/
 */
const WEB3FORMS_KEY = 'c0bd1321-2868-459f-9002-4924bc8553fe';
---

<form
  action="https://api.web3forms.com/submit"
  method="POST"
  data-phone={business.phoneDisplay}
  class={`space-y-5 ${className}`.trim()}
  id="contact-form"
>
  <!-- Web3Forms config -->
  <input type="hidden" name="access_key" value={WEB3FORMS_KEY} />
  <input type="hidden" name="redirect" value={`${business.url}/merci`} />
  <input type="hidden" name="from_name" value={business.name} />
  <input type="hidden" name="subject" value={`Nouvelle demande de rappel — ${business.name}`} />

  <!-- Honeypot anti-spam -->
  <input type="checkbox" name="botcheck" class="hidden" style="display: none;" tabindex="-1" autocomplete="off" />

  <!-- Nom -->
  <div>
    <label for="name" class="block text-sm font-medium text-secondary-900 mb-1.5">
      Votre nom <span class="text-red-500" aria-hidden="true">*</span>
      <span class="sr-only">(obligatoire)</span>
    </label>
    <input
      type="text"
      id="name"
      name="name"
      required
      autocomplete="name"
      class="w-full px-4 py-3 bg-neutral-50 border border-neutral-300 rounded-DEFAULT text-secondary-900 placeholder-neutral-400 focus:border-primary-500 focus:ring-2 focus:ring-primary-500/20 focus:outline-none transition-colors min-h-[44px]"
      placeholder="Jean Dupont"
    />
  </div>

  <!-- Téléphone -->
  <div>
    <label for="phone" class="block text-sm font-medium text-secondary-900 mb-1.5">
      Votre téléphone <span class="text-red-500" aria-hidden="true">*</span>
      <span class="sr-only">(obligatoire)</span>
    </label>
    <input
      type="tel"
      id="phone"
      name="phone"
      required
      autocomplete="tel"
      class="w-full px-4 py-3 bg-neutral-50 border border-neutral-300 rounded-DEFAULT text-secondary-900 placeholder-neutral-400 focus:border-primary-500 focus:ring-2 focus:ring-primary-500/20 focus:outline-none transition-colors min-h-[44px]"
      placeholder="06 12 34 56 78"
    />
  </div>

  <!-- Type de demande -->
  <div>
    <label for="request-type" class="block text-sm font-medium text-secondary-900 mb-1.5">
      Type de demande <span class="text-red-500" aria-hidden="true">*</span>
      <span class="sr-only">(obligatoire)</span>
    </label>
    <select
      id="request-type"
      name="request_type"
      required
      class="w-full px-4 py-3 bg-neutral-50 border border-neutral-300 rounded-DEFAULT text-secondary-900 focus:border-primary-500 focus:ring-2 focus:ring-primary-500/20 focus:outline-none transition-colors min-h-[44px] appearance-none bg-[url('data:image/svg+xml;charset=utf-8,%3Csvg%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%20width%3D%2212%22%20height%3D%2212%22%20viewBox%3D%220%200%2012%2012%22%3E%3Cpath%20fill%3D%22%236b7280%22%20d%3D%22M6%208L1%203h10z%22%2F%3E%3C%2Fsvg%3E')] bg-[length:12px] bg-[right_16px_center] bg-no-repeat"
    >
      <option value="" disabled selected>Choisissez un type</option>
      <option value="Dépannage électrique">Dépannage électrique</option>
      <option value="Rénovation">Rénovation</option>
      <option value="Installation neuve">Installation neuve</option>
    </select>
  </div>

  <!-- Créneau de rappel préféré -->
  <div>
    <label for="callback-slot" class="block text-sm font-medium text-secondary-900 mb-1.5">
      Créneau de rappel préféré <span class="text-neutral-400 text-xs font-normal">(optionnel)</span>
    </label>
    <select
      id="callback-slot"
      name="callback_slot"
      class="w-full px-4 py-3 bg-neutral-50 border border-neutral-300 rounded-DEFAULT text-secondary-900 focus:border-primary-500 focus:ring-2 focus:ring-primary-500/20 focus:outline-none transition-colors min-h-[44px] appearance-none bg-[url('data:image/svg+xml;charset=utf-8,%3Csvg%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%20width%3D%2212%22%20height%3D%2212%22%20viewBox%3D%220%200%2012%2012%22%3E%3Cpath%20fill%3D%22%236b7280%22%20d%3D%22M6%208L1%203h10z%22%2F%3E%3C%2Fsvg%3E')] bg-[length:12px] bg-[right_16px_center] bg-no-repeat"
    >
      <option value="">Peu importe</option>
      <option value="8h-10h">8h – 10h</option>
      <option value="10h-12h">10h – 12h</option>
      <option value="12h-14h">12h – 14h</option>
      <option value="14h-16h">14h – 16h</option>
      <option value="16h-18h">16h – 18h</option>
    </select>
  </div>

  <!-- Message -->
  <div>
    <label for="message" class="block text-sm font-medium text-secondary-900 mb-1.5">
      Message <span class="text-neutral-400 text-xs font-normal">(optionnel)</span>
    </label>
    <textarea
      id="message"
      name="message"
      rows={3}
      class="w-full px-4 py-3 bg-neutral-50 border border-neutral-300 rounded-DEFAULT text-secondary-900 placeholder-neutral-400 focus:border-primary-500 focus:ring-2 focus:ring-primary-500/20 focus:outline-none transition-colors resize-y"
      placeholder="Précisions supplémentaires..."
    ></textarea>
  </div>

  <!-- Mention RGPD -->
  <p class="text-xs text-neutral-600 leading-relaxed">
    En soumettant ce formulaire, vous acceptez que vos données soient traitées conformément à notre
    <a href="/politique-confidentialite" class="underline hover:text-primary-600 transition-colors">politique de confidentialité</a>.
    Vos informations sont uniquement utilisées pour répondre à votre demande et ne sont jamais partagées avec des tiers.
  </p>

  <!-- Submit -->
  <div>
    <Button type="submit" size="lg" class="w-full sm:w-auto">
      Demander un rappel
    </Button>
  </div>

  <!-- Status message -->
  <div id="form-status" class="hidden" role="alert" aria-live="polite"></div>
</form>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const status = document.getElementById('form-status');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();

    if (!status) return;

    const submitBtn = form.querySelector('button[type="submit"]') as HTMLButtonElement | null;
    const originalText = submitBtn?.textContent || '';

    // Loading state
    if (submitBtn) {
      submitBtn.disabled = true;
      submitBtn.textContent = 'Envoi en cours...';
    }
    status.className = 'hidden';

    try {
      const formData = new FormData(form);
      const response = await fetch('https://api.web3forms.com/submit', {
        method: 'POST',
        body: formData,
      });

      const data = await response.json();

      if (data.success) {
        // Redirect to /merci
        window.location.href = '/merci';
      } else {
        status.textContent = 'Une erreur est survenue. Veuillez réessayer ou nous contacter par téléphone.';
        status.className = 'text-sm text-red-600 bg-red-50 border border-red-200 rounded-DEFAULT p-3';
        if (submitBtn) {
          submitBtn.disabled = false;
          submitBtn.textContent = originalText;
        }
      }
    } catch {
      status.textContent = `Erreur de connexion. Veuillez réessayer ou nous appeler au ${form.dataset.phone}.`;
      status.className = 'text-sm text-red-600 bg-red-50 border border-red-200 rounded-DEFAULT p-3';
      if (submitBtn) {
        submitBtn.disabled = false;
        submitBtn.textContent = originalText;
      }
    }
  });
</script>
